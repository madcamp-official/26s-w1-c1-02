# 로그인/회원가입 (MongoDB Atlas + JWT)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/minigame?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-random-secret-string

# 게임(자음 모음 조합) — 로컬 Postgres. docker-compose 사용 시 기본값이 주입되어 보통 생략 가능
# DATABASE_URL=postgres://mgh:mgh_dev_pw@db:5432/minigameheaven

# 국립국어원 표준국어대사전 Open API 키 (선택) — 로컬 DB에 없는 단어 폴백 검증용
STDICT_API_KEY=
