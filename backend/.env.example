# 실제 값을 채워 이 디렉터리에 .env 로 저장하세요. (backend/.env 는 .gitignore 됨)

# 로그인 토큰(JWT) 서명 키 — 아무 랜덤 문자열 (예: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-secret-string

# 계정 + 게임 데이터 — 단일 Postgres. docker-compose 사용 시 기본값이 주입되어 보통 생략 가능
# DATABASE_URL=postgres://mgh:mgh_dev_pw@db:5432/minigameheaven

# 국립국어원 표준국어대사전 Open API 키 (선택) — 로컬 DB에 없는 단어 폴백 검증용
STDICT_API_KEY=

# 소셜 로그인 (선택) — 각 플랫폼 개발자 콘솔에서 발급. 리다이렉트 URI는 서비스 도메인에 맞게 변경
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://your-domain/auth/kakao/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain/auth/google/callback

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://your-domain/auth/naver/callback
